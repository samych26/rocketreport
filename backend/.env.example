APP_ENV=prod
APP_SECRET=change_me_32_char_random_string

DATABASE_URL="mysql://rocketreport:CHANGE_ME_PASSWORD@127.0.0.1:3306/rocket_report?serverVersion=8.0.32&charset=utf8mb4"

JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me_strong_passphrase
JWT_TTL=3600

MAILER_DSN=smtp://resend:YOUR_RESEND_API_KEY@smtp.resend.com:465
MAILER_FROM_ADDRESS=no-reply@yourdomain.com
MAILER_FROM_NAME="RocketReport"

CORS_ALLOW_ORIGIN='^https://yourdomain\.com$'
FRONTEND_URL=https://yourdomain.com
DEFAULT_URI=https://yourdomain.com

GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

REDIS_URL=redis://localhost:6379

MESSENGER_TRANSPORT_DSN=doctrine://default?queue_name=async

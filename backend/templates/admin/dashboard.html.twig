{% extends '@EasyAdmin/page/content.html.twig' %}

{% block page_title %}Dashboard{% endblock %}

{% block main %}
<div class="row g-4 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card text-white bg-primary">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="fa fa-users fa-2x opacity-75"></i>
                <div><div class="fs-4 fw-bold">{{ users_count }}</div><div class="small">Utilisateurs</div></div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card text-white bg-success">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="fa fa-plug fa-2x opacity-75"></i>
                <div><div class="fs-4 fw-bold">{{ sources_count }}</div><div class="small">Sources API</div></div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card text-white bg-info">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="fa fa-file-alt fa-2x opacity-75"></i>
                <div><div class="fs-4 fw-bold">{{ documents_count }}</div><div class="small">Documents</div></div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card text-white bg-warning">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="fa fa-cogs fa-2x opacity-75"></i>
                <div><div class="fs-4 fw-bold">{{ generations_count }}</div><div class="small">Générations</div></div>
            </div>
        </div>
    </div>
</div>
<div class="card">
    <div class="card-header fw-bold">🚀 Bienvenue dans RocketReport Admin</div>
    <div class="card-body"><p>Gérez vos utilisateurs, sources API, documents, templates et générations depuis ce panneau.</p></div>
</div>
{% endblock %}